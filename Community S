            style={styles.reportAddBtn}
            onPress={() => Alert.alert('Report Area', 'Mark the current location as unsafe?', [
              { text: 'Cancel' },
              { text: 'Report ⚠️', onPress: () => Alert.alert('Thank you!', 'Your report has been submitted.') },
            ])}
          >
            <Text style={styles.reportAddText}>⚠️ Report Unsafe Area</Text>
          </TouchableOpacity>

          <View style={{ height: 80 }} />
        </ScrollView>
      )}

      {/* ── TAB: Self Defense ─────────────────────────────────────────────── */}
      {activeTab === 'tips' && (
        <ScrollView contentContainerStyle={styles.tabContent} showsVerticalScrollIndicator={false}>
          {/* Lang toggle */}
          <View style={styles.langRow}>
            <TouchableOpacity
              style={[styles.langBtn, language === 'en' && styles.langBtnActive]}
              onPress={() => setLanguage('en')}
            >
              <Text style={[styles.langText, language === 'en' && styles.langTextActive]}>🇬🇧 English</Text>
            </TouchableOpacity>
            <TouchableOpacity
              style={[styles.langBtn, language === 'hi' && styles.langBtnActive]}
              onPress={() => setLanguage('hi')}
            >
              <Text style={[styles.langText, language === 'hi' && styles.langTextActive]}>🇮🇳 हिंदी</Text>
            </TouchableOpacity>
          </View>

          {SELF_DEFENSE_TIPS.map(tip => (
            <TouchableOpacity
              key={tip.id}
              style={[styles.tipCard, { borderLeftColor: tip.color }]}
              onPress={() => setExpandedTip(expandedTip === tip.id ? null : tip.id)}
              activeOpacity={0.8}
            >
              <View style={styles.tipHeader}>
                <View style={[styles.tipIconCircle, { backgroundColor: tip.color + '22' }]}>
                  <Text style={styles.tipEmoji}>{tip.emoji}</Text>
                </View>
                <View style={{ flex: 1 }}>
                  <Text style={[styles.tipTitle, { color: tip.color }]}>
                    {language === 'en' ? tip.title : tip.titleHi}
                  </Text>
                  <Text style={styles.tipSub}>Tap to expand</Text>
                </View>
                <Text style={styles.tipArrow}>{expandedTip === tip.id ? '▲' : '▼'}</Text>
              </View>
              {expandedTip === tip.id && (
                <View style={styles.tipSteps}>
                  {(language === 'en' ? tip.steps : tip.stepsHi).map((step, i) => (
                    <View key={i} style={styles.stepRow}>
                      <View style={[styles.stepNum, { backgroundColor: tip.color }]}>
                        <Text style={styles.stepNumText}>{i + 1}</Text>
                      </View>
                      <Text style={styles.stepText}>{step}</Text>
                    </View>
                  ))}
                </View>
              )}
            </TouchableOpacity>
          ))}
          <View style={{ height: 80 }} />
        </ScrollView>
      )}

      {/* ── TAB: Help Me ─────────────────────────────────────────────────── */}
      {activeTab === 'help' && (
        <View style={styles.helpCenterContent}>
          {!helpSent ? (
            <>
              <Text style={styles.helpTitle}>Need immediate help?</Text>
              <Text style={styles.helpSub}>
                Pressing this button will silently alert all SafeGuard users within 500 meters.
                Your identity stays completely anonymous.
              </Text>
              <View style={styles.helpBtnContainer}>
                <Animated.View style={{ transform: [{ scale: helpPulse }] }}>
                  <TouchableOpacity
                    style={styles.helpBtn}
                    onPress={handleHelpMe}
                    disabled={isLoadingHelp}
                    activeOpacity={0.85}
                  >
                    <LinearGradient colors={['#FF1744', '#D50000']} style={styles.helpBtnGrad}>
                      <Text style={styles.helpBtnEmoji}>🆘</Text>
                      <Text style={styles.helpBtnText}>
                        {isLoadingHelp ? 'Alerting...' : 'HELP ME'}
                      </Text>
                      <Text style={styles.helpBtnSub}>Anonymous · Instant</Text>
                    </LinearGradient>
                  </TouchableOpacity>
                </Animated.View>
              </View>
              <View style={styles.helpInfoRow}>
                <View style={styles.helpInfoCard}><Text style={styles.helpInfoEmoji}>🔒</Text><Text style={styles.helpInfoText}>100% Anonymous</Text></View>
                <View style={styles.helpInfoCard}><Text style={styles.helpInfoEmoji}>📡</Text><Text style={styles.helpInfoText}>500m radius alert</Text></View>
                <View style={styles.helpInfoCard}><Text style={styles.helpInfoEmoji}>⚡</Text><Text style={styles.helpInfoText}>Instant notify</Text></View>
              </View>
            </>
          ) : (
            <View style={styles.helpSentContainer}>
              <Text style={styles.helpSentEmoji}>✅</Text>
              <Text style={styles.helpSentTitle}>Alert Sent!</Text>
              <Text style={styles.helpSentCount}>
                <Text style={{ color: colors.primary, fontSize: 40, fontWeight: '900' }}>{helpCount}</Text>
                {'\n'}nearby SafeGuard users alerted
              </Text>
              <Text style={styles.helpSentNote}>
                Help should arrive within minutes.{'\n'}Stay visible and keep your phone accessible.
              </Text>
              <TouchableOpacity style={styles.helpResetBtn} onPress={() => { setHelpSent(false); setHelpCount(0); }}>
                <Text style={styles.helpResetText}>I'm Safe Now ✅</Text>
              </TouchableOpacity>
            </View>
          )}
        </View>
      )}
    </View>
  );
}

