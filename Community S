export default function CommunityScreen() {
  const [activeTab, setActiveTab] = useState<CommunityTab>('map');
  const [language, setLanguage] = useState<Language>('en');
  const [expandedTip, setExpandedTip] = useState<string | null>(null);
  const [helpCount, setHelpCount] = useState(0);
  const [helpSent, setHelpSent] = useState(false);
  const [isLoadingHelp, setIsLoadingHelp] = useState(false);
  const helpPulse = useRef(new Animated.Value(1)).current;

  useEffect(() => {
    startHelpPulse();
  }, []);

  const startHelpPulse = () => {
    Animated.loop(
      Animated.sequence([
        Animated.timing(helpPulse, { toValue: 1.08, duration: 800, useNativeDriver: true }),
        Animated.timing(helpPulse, { toValue: 1, duration: 800, useNativeDriver: true }),
      ])
    ).start();
  };

  const handleHelpMe = async () => {
    setIsLoadingHelp(true);
    const { status } = await Location.requestForegroundPermissionsAsync();
    setTimeout(() => {
      const count = Math.floor(Math.random() * 12) + 3;
      setHelpCount(count);
      setHelpSent(true);
      setIsLoadingHelp(false);
      // In production: write to Firebase helpRequests collection,
      // cloud function triggers notification to nearby users within 500m
    }, 1500);
  };

  const markerColor = (type: string) => {
    if (type === 'danger') return colors.primary;
    if (type === 'caution') return colors.warning;
    return colors.success;
  };

  return (
    <View style={styles.container}>
      <LinearGradient colors={['#FFEBEE', '#FCE4EC', '#FFF0F5']} style={StyleSheet.absoluteFillObject} />

      {/* Header */}
      <View style={styles.header}>
        <Text style={styles.headerTitle}>🌍 Community Safety</Text>
      </View>

      {/* Tab bar */}
      <View style={styles.tabBar}>
        {(['map', 'tips', 'help'] as CommunityTab[]).map(tab => (
          <TouchableOpacity
            key={tab}
            style={[styles.tab, activeTab === tab && styles.tabActive]}
            onPress={() => setActiveTab(tab)}
          >
            <Text style={[styles.tabText, activeTab === tab && styles.tabTextActive]}>
              {tab === 'map' ? '🗺️ Safety Map' : tab === 'tips' ? '🥋 Self Defense' : '🆘 Help Me'}
            </Text>
          </TouchableOpacity>
        ))}
      </View>

      {/* ── TAB: Safety Map ──────────────────────────────────────────────── */}
      {activeTab === 'map' && (
        <ScrollView contentContainerStyle={styles.tabContent} showsVerticalScrollIndicator={false}>
          {/* Map placeholder (react-native-maps would render here) */}
          <View style={styles.mapPlaceholder}>
            <LinearGradient colors={['#2D3825', '#414535']} style={StyleSheet.absoluteFillObject} />
            <Text style={styles.mapPlaceholderText}>🗺️</Text>
            <Text style={styles.mapPlaceholderLabel}>Dark Safety Map</Text>
            <Text style={styles.mapPlaceholderSub}>
              (Requires react-native-maps + Google Maps API key configured in app.json)
            </Text>
            {/* Simulated markers */}
            <View style={styles.markerLegend}>
              <View style={styles.legendItem}><View style={[styles.legendDot, { backgroundColor: colors.primary }]} /><Text style={styles.legendText}>Danger Zone</Text></View>
              <View style={styles.legendItem}><View style={[styles.legendDot, { backgroundColor: colors.warning }]} /><Text style={styles.legendText}>Caution Area</Text></View>
              <View style={styles.legendItem}><View style={[styles.legendDot, { backgroundColor: colors.success }]} /><Text style={styles.legendText}>Safe Zone</Text></View>
            </View>
          </View>

          {/* Recent reports */}
          <Text style={styles.sectionTitle}>📋 Community Reports</Text>
          {DEMO_MARKERS.map(m => (
            <View key={m.id} style={[styles.reportCard, { borderLeftColor: markerColor(m.type) }]}>
              <View style={styles.reportLeft}>
                <View style={[styles.reportDot, { backgroundColor: markerColor(m.type) }]} />
                <View>
                  <Text style={styles.reportLabel}>{m.label}</Text>
                  <Text style={styles.reportTime}>{m.time} · {m.votes} reports</Text>
                </View>
              </View>
              <View style={styles.voteRow}>
                <TouchableOpacity style={styles.voteBtn}><Text style={styles.voteText}>👍</Text></TouchableOpacity>
                <TouchableOpacity style={styles.voteBtn}><Text style={styles.voteText}>👎</Text></TouchableOpacity>
              </View>
            </View>
          ))}

          {/* Report button */}
