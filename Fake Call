// ============================================================
// SafeGuard — FakeCallScreen.tsx
// Simulates an incoming call with configurable name/delay
// Features: preset callers, timer options, ringtone (expo-av),
// vibration, realistic call UI, shake-to-trigger
// ============================================================

import React, { useState, useEffect, useRef } from 'react';
import {
  View,
  Text,
  TouchableOpacity,
  StyleSheet,
  Animated,
  Vibration,
  Alert,
  Dimensions,
  Platform,
} from 'react-native';
import { LinearGradient } from 'expo-linear-gradient';
import { NavigationProp } from '@react-navigation/native';
import { Accelerometer } from 'expo-sensors';
import { Audio } from 'expo-av';
import { colors, spacing, borderRadius, typography } from '../constants/theme';

import { RootStackParamList } from '../../App';

interface Props {
  navigation: NavigationProp<RootStackParamList>;
  onLogin: () => void;
}

type CallState = 'setup' | 'ringing' | 'active';

const PRESET_CALLERS = [
  { name: 'Mom', emoji: '👩', subtitle: 'Mobile' },
  { name: 'Dad', emoji: '👨', subtitle: 'Mobile' },
  { name: 'Friend', emoji: '👯', subtitle: 'Mobile' },
  { name: 'Police', emoji: '👮', subtitle: 'Emergency' },
  { name: 'Boss', emoji: '💼', subtitle: 'Work' },
  { name: 'Doctor', emoji: '👨‍⚕️', subtitle: 'Clinic' },
];

const TIMER_OPTIONS = [
  { label: 'Now', seconds: 0 },
  { label: '10s', seconds: 10 },
  { label: '30s', seconds: 30 },
  { label: '60s', seconds: 60 },
];

const { width, height } = Dimensions.get('window');

export default function FakeCallScreen({ navigation }: Props) {
  const [callState, setCallState] = useState<CallState>('setup');
  const [selectedCaller, setSelectedCaller] = useState(PRESET_CALLERS[0]);
  const [selectedTimer, setSelectedTimer] = useState(TIMER_OPTIONS[0]);
  const [callDuration, setCallDuration] = useState(0);
  const [countdown, setCountdown] = useState(0);

  const timerRef = useRef<ReturnType<typeof setInterval> | null>(null);
  const countdownRef = useRef<ReturnType<typeof setInterval> | null>(null);
  const ringAnim = useRef(new Animated.Value(0)).current;
  const avatarPulse = useRef(new Animated.Value(1)).current;
  const slideAnswer = useRef(new Animated.Value(0)).current;
  const accelSub = useRef<ReturnType<typeof Accelerometer.addListener> | null>(null);
  const soundRef = useRef<Audio.Sound | null>(null);


  useEffect(() => {
    setupShakeDetection();
    return () => {
      cleanup();
    };
  }, []);

  useEffect(() => {
    if (callState === 'ringing') {
      startRingAnimation();
      startVibration();
      playRingtone();
    } else {
      stopRingtone();
      Vibration.cancel();
    }
  }, [callState]);


  // ── Shake detection ──────────────────────────────────────────────────────
  const setupShakeDetection = () => {
    if (Platform.OS === 'web') {
      console.log('Accelerometer not supported on web.');
      return;
    }
    try {
      Accelerometer.setUpdateInterval(300);
      let lastMagnitude = 0;
      accelSub.current = Accelerometer.addListener(({ x, y, z }) => {
        const magnitude = Math.sqrt(x * x + y * y + z * z);
        if (magnitude > 2.5 && lastMagnitude < 2.5) {
          // Shake detected — start fake call in 5s
          scheduleCall(5);
        }
        lastMagnitude = magnitude;
      });
    } catch (error) {
      console.warn('Accelerometer setup failed:', error);
    }
  };


  const scheduleCall = (seconds: number) => {
    if (callState !== 'setup') return;
    if (seconds === 0) {
      triggerRinging();
      return;
    }
    setCountdown(seconds);
    countdownRef.current = setInterval(() => {
      setCountdown(prev => {
        if (prev <= 1) {
          clearInterval(countdownRef.current!);
          triggerRinging();
          return 0;
        }
        return prev - 1;
      });
    }, 1000);
  };

  const triggerRinging = () => {
    setCallState('ringing');
    setCountdown(0);
  };

  const startRingAnimation = () => {
    Animated.loop(
      Animated.sequence([
        Animated.timing(ringAnim, { toValue: 1, duration: 300, useNativeDriver: true }),
        Animated.timing(ringAnim, { toValue: 0, duration: 300, useNativeDriver: true }),
      ])
    ).start();
    Animated.loop(
      Animated.sequence([
        Animated.timing(avatarPulse, { toValue: 1.1, duration: 600, useNativeDriver: true }),
        Animated.timing(avatarPulse, { toValue: 1, duration: 600, useNativeDriver: true }),
      ])
    ).start();
    // Answer slider
    Animated.loop(
      Animated.sequence([
        Animated.timing(slideAnswer, { toValue: 1, duration: 700, useNativeDriver: true }),
        Animated.timing(slideAnswer, { toValue: 0, duration: 300, useNativeDriver: true }),
      ])
    ).start();
  };

  const startVibration = () => {
    Vibration.vibrate([0, 1000, 500, 1000, 500, 1000], true);
  };

  const playRingtone = async () => {
    try {
      // Standard ringtone URL
      const { sound } = await Audio.Sound.createAsync(
        { uri: 'https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3' }, // Placeholder ringtone
        { shouldPlay: true, isLooping: true }
      );
      soundRef.current = sound;
      await sound.playAsync();
    } catch (error) {
      console.log('Error playing ringtone:', error);
    }
  };

  const stopRingtone = async () => {
    if (soundRef.current) {
      try {
        await soundRef.current.stopAsync();
        await soundRef.current.unloadAsync();
        soundRef.current = null;
      } catch (error) {
        console.log('Error stopping ringtone:', error);
      }
    }
  };


  const answerCall = () => {
    ringAnim.stopAnimation();
    avatarPulse.stopAnimation();
    Vibration.cancel();
    setCallState('active');
    setCallDuration(0);
    timerRef.current = setInterval(() => {
      setCallDuration(prev => prev + 1);
    }, 1000);
  };

  const rejectCall = () => {
    Vibration.cancel();
    ringAnim.stopAnimation();
    avatarPulse.stopAnimation();
    setCallState('setup');
  };

  const endCall = () => {
    if (timerRef.current) clearInterval(timerRef.current);
    setCallState('setup');
    setCallDuration(0);
  };

  const cleanup = () => {
    if (timerRef.current) clearInterval(timerRef.current);
    if (countdownRef.current) clearInterval(countdownRef.current);
    accelSub.current?.remove();
    Vibration.cancel();
    stopRingtone();
  };


  const formatDuration = (s: number) => {
    const m = Math.floor(s / 60).toString().padStart(2, '0');
    const sec = (s % 60).toString().padStart(2, '0');
    return `${m}:${sec}`;
  };

  // ── Render: Setup screen ───────────────────────────────────────────────
  if (callState === 'setup') {
    return (
      <View style={styles.container}>
        <LinearGradient colors={['#96BBBB', '#AACECE', '#96BBBB']} style={StyleSheet.absoluteFillObject} />

        <View style={styles.header}>
          <TouchableOpacity onPress={() => navigation.goBack()} style={styles.backBtn}>
            <Text style={styles.backText}>← Back</Text>
          </TouchableOpacity>
          <Text style={styles.headerTitle}>📞 Fake Call</Text>
          <View style={{ width: 60 }} />
        </View>

        <View style={styles.setupContent}>
          {/* Caller selection */}
          <Text style={styles.sectionLabel}>Choose Caller</Text>
          <View style={styles.callerGrid}>
            {PRESET_CALLERS.map(caller => (
              <TouchableOpacity
                key={caller.name}
                style={[styles.callerCard, selectedCaller.name === caller.name && styles.callerCardActive]}
                onPress={() => setSelectedCaller(caller)}
              >
                <Text style={styles.callerEmoji}>{caller.emoji}</Text>
                <Text style={[styles.callerName, selectedCaller.name === caller.name && { color: colors.primary }]}>
                  {caller.name}
                </Text>
              </TouchableOpacity>
            ))}
          </View>

          {/* Timer selection */}
          <Text style={styles.sectionLabel}>Call Delay</Text>
          <View style={styles.timerRow}>
            {TIMER_OPTIONS.map(opt => (
              <TouchableOpacity
                key={opt.label}
                style={[styles.timerCard, selectedTimer.label === opt.label && styles.timerCardActive]}
                onPress={() => setSelectedTimer(opt)}
              >
                <Text style={[styles.timerLabel, selectedTimer.label === opt.label && styles.timerLabelActive]}>
                  {opt.label}
                </Text>
              </TouchableOpacity>
            ))}
          </View>

          {countdown > 0 && (
            <View style={styles.countdownBanner}>
              <Text style={styles.countdownBannerText}>📞 Call in {countdown}s...</Text>
            </View>
          )}

          {/* Trigger button */}
          <TouchableOpacity
            style={styles.triggerBtn}
            onPress={() => scheduleCall(selectedTimer.seconds)}
          >
            <LinearGradient colors={[colors.primary, colors.accent]} style={styles.triggerGrad}>
              <Text style={styles.triggerText}>
                {selectedTimer.seconds === 0 ? '📞 Trigger Call Now' : `📞 Call in ${selectedTimer.label}`}
              </Text>
            </LinearGradient>
          </TouchableOpacity>

          {/* Shake tip */}
          <View style={styles.shakeCard}>
            <Text style={styles.shakeTitle}>📳 Shake to Trigger</Text>
            <Text style={styles.shakeText}>
              Shake your phone at any time to trigger a fake call in 5 seconds. Works discreetly without tapping anything.
            </Text>
          </View>
        </View>
      </View>
    );
  }

  // ── Render: Ringing screen ─────────────────────────────────────────────
  if (callState === 'ringing') {
    return (
      <View style={styles.callScreen}>
        <LinearGradient colors={['#96BBBB', '#AACECE', '#96BBBB']} style={StyleSheet.absoluteFillObject} />

        <View style={styles.callHeader}>
          <Text style={styles.callStatus}>Incoming Call...</Text>
          <Text style={styles.callNetwork}>SafeGuard</Text>
        </View>

        <Animated.View style={[styles.callAvatar, { transform: [{ scale: avatarPulse }] }]}>
          <LinearGradient colors={[colors.card, colors.background]} style={styles.callAvatarGrad}>
            <Text style={styles.callAvatarEmoji}>{selectedCaller.emoji}</Text>
          </LinearGradient>
        </Animated.View>

        <Text style={styles.callerDisplayName}>{selectedCaller.name}</Text>
        <Text style={styles.callerSubtitle}>{selectedCaller.subtitle}</Text>

        {/* Slide hint */}
        <Animated.Text style={[styles.slideHint, { opacity: slideAnswer }]}>← Slide to Answer →</Animated.Text>

        <View style={styles.callActions}>
          {/* Reject */}
          <TouchableOpacity style={[styles.callActionBtn, styles.rejectBtn]} onPress={rejectCall}>
            <Text style={styles.callActionEmoji}>📵</Text>
            <Text style={styles.callActionLabel}>Decline</Text>
          </TouchableOpacity>
          {/* Answer */}
          <TouchableOpacity style={[styles.callActionBtn, styles.answerBtn]} onPress={answerCall}>
            <Text style={styles.callActionEmoji}>📞</Text>
            <Text style={styles.callActionLabel}>Answer</Text>
          </TouchableOpacity>
        </View>
      </View>
    );
  }

  // ── Render: Active call screen ─────────────────────────────────────────
  return (
    <View style={styles.callScreen}>
      <LinearGradient colors={['#96BBBB', '#AACECE', '#96BBBB']} style={StyleSheet.absoluteFillObject} />

      <View style={styles.callHeader}>
        <Text style={styles.callStatus}>{formatDuration(callDuration)}</Text>
        <Text style={styles.callNetwork}>SafeGuard</Text>
      </View>

      <View style={styles.callAvatar}>
        <LinearGradient colors={[colors.success + '44', colors.card]} style={styles.callAvatarGrad}>
          <Text style={styles.callAvatarEmoji}>{selectedCaller.emoji}</Text>
        </LinearGradient>
      </View>

      <Text style={styles.callerDisplayName}>{selectedCaller.name}</Text>
      <Text style={[styles.callerSubtitle, { color: colors.success }]}>On call...</Text>

      {/* In-call buttons */}
      <View style={styles.inCallGrid}>
        {[
          { emoji: '🔇', label: 'Mute' },
          { emoji: '🔊', label: 'Speaker' },
          { emoji: '⌨️', label: 'Keypad' },
          { emoji: '📷', label: 'Video' },
        ].map(btn => (
          <TouchableOpacity key={btn.label} style={styles.inCallBtn}>
            <Text style={styles.inCallBtnEmoji}>{btn.emoji}</Text>
            <Text style={styles.inCallBtnLabel}>{btn.label}</Text>
          </TouchableOpacity>
        ))}
      </View>

      {/* End call */}
      <TouchableOpacity style={styles.endCallBtn} onPress={endCall}>
        <View style={styles.endCallCircle}>
          <Text style={styles.endCallEmoji}>📵</Text>
        </View>
        <Text style={styles.endCallLabel}>End Call</Text>
      </TouchableOpacity>
    </View>
  );
}

