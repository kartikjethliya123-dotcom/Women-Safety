  timerLabelActive: { color: colors.textLight },
  countdownBanner: {
    backgroundColor: colors.success + '22',
    borderRadius: borderRadius.md,
    padding: spacing.sm,
    alignItems: 'center',
    marginBottom: spacing.md,
    borderWidth: 1,
    borderColor: colors.success,
  },
  countdownBannerText: { color: colors.success, fontSize: 16, fontWeight: '700' },
  triggerBtn: { borderRadius: borderRadius.md, overflow: 'hidden', marginBottom: spacing.lg },
  triggerGrad: { paddingVertical: spacing.md, alignItems: 'center' },
