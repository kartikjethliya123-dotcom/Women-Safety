  },
  shakeTitle: { color: colors.accent, fontSize: 14, fontWeight: '700', marginBottom: 6 },
  shakeText: { color: colors.textSecondary, fontSize: 13, lineHeight: 20 },
  // Call screens
  callScreen: { flex: 1, backgroundColor: colors.background, alignItems: 'center' },
  callHeader: { marginTop: 60, alignItems: 'center', marginBottom: 30 },
